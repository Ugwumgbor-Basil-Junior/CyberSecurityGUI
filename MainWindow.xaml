<Window x:Class="CyberSecurityGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CyberSecurityGUI"
        mc:Ignorable="d"
        Title="Cybersecurity Intelligence Assistant"
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A">

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain"       Color="#0A0A0A"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#111111"/>
        <SolidColorBrush x:Key="BgBubbleBot"  Color="#1A0000"/>
        <SolidColorBrush x:Key="BgBubbleUser" Color="#0D0D0D"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#FF2222"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#FF6600"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E8E8E8"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#555555"/>
        <SolidColorBrush x:Key="BorderCol"    Color="#FF2222"/>

        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#FF2222" CornerRadius="2" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="5"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                                       Style="{StaticResource SlimScrollBar}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputBoxStyle" TargetType="TextBox">

            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="Background" Value="#0D0D0D"/>
            <Setter Property="CaretBrush" Value="#FF2222"/>
            <Setter Property="BorderBrush" Value="#FF2222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,8"/>

        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#8B0000"/>
            <Setter Property="Foreground"      Value="#FF2222"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="2" Padding="18,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#AA0000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipStyle" TargetType="Button">
            <Setter Property="Background"      Value="#1A0000"/>
            <Setter Property="Foreground"      Value="#FF2222"/>
            <Setter Property="BorderBrush"     Value="#FF2222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2" Padding="12,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A0000"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF6600"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BgMain}">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderCol}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="44" Height="44"
                        Background="#1A0000" CornerRadius="2" VerticalAlignment="Center"
                        BorderBrush="#FF2222" BorderThickness="1">
                    <TextBlock Text="⚠" FontSize="22"
                               Foreground="#FF2222"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="CYBERSECURITY INTELLIGENCE SYSTEM"
                               Foreground="{StaticResource AccentRed}"
                               FontSize="15" FontWeight="Bold" FontFamily="Consolas"/>
                    <TextBlock Text="// threat awareness &amp; digital defence protocol"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="11" FontFamily="Consolas"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#FF2222"
                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="ACTIVE" Foreground="#FF2222"
                               FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CHAT AREA -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScroll"
                      Style="{StaticResource ChatScrollViewer}" Padding="0,8">
            <StackPanel x:Name="MessagePanel" Margin="16,4"/>
        </ScrollViewer>

        <!-- QUICK CHIPS -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderCol}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        HorizontalAlignment="Left" Margin="16,0">
                <TextBlock Text="// quick access:" Foreground="{StaticResource TextMuted}"
                           FontSize="11" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Style="{StaticResource ChipStyle}" Content="[PASSWORDS]"
                        Click="Chip_Click" Tag="Tell me about passwords"/>
                <Button Style="{StaticResource ChipStyle}" Content="[PHISHING]"
                        Click="Chip_Click" Tag="What is phishing?"/>
                <Button Style="{StaticResource ChipStyle}" Content="[MALWARE]"
                        Click="Chip_Click" Tag="Tell me about malware"/>
                <Button Style="{StaticResource ChipStyle}" Content="[PRIVACY]"
                        Click="Chip_Click" Tag="Tell me about privacy"/>
                <Button Style="{StaticResource ChipStyle}" Content="[HELP]"
                        Click="Chip_Click" Tag="What can you help me with?"/>
            </StackPanel>
        </Border>

        <!-- INPUT BAR -->
        <Border Grid.Row="3" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderCol}"
                BorderThickness="0,1,0,0" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&gt;_" Foreground="#FF2222"
                           FontFamily="Consolas" FontSize="16"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="1" x:Name="InputBox"
                         Style="{StaticResource InputBoxStyle}"
                         Foreground="#E8E8E8"
                         Background="#0D0D0D"
                         FontFamily="Segoe UI"
                         Height="38" VerticalContentAlignment="Center"
                         KeyDown="InputBox_KeyDown"/>
                <Button Grid.Column="2" x:Name="SendButton"
                        Style="{StaticResource SendButtonStyle}"
                        Content="EXECUTE" Height="38" Margin="8,0,0,0"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>